{# Autocomplete simple #}
<template x-if="field.type === 'autocomplete' && !field.multiple">
    <div class="relative">
        <input type="text" :ref="`input_${field.name}`" x-model="inputLabels[field.name]"
               @input.debounce.300ms="fetchSuggestions(field.name, $event.target.value)"
               autocomplete="off"
               placeholder="Start typing or add a new value..."
               class="w-full py-1.5 px-3 text-sm border border-gray-300 rounded-md"/>
        <input type="hidden" :name="field.name" :value="formData.fields[field.name]"/>

        <ul x-show="suggestions[field.name]?.length > 0"
          
            class="absolute z-10 bg-white border border-gray-300 rounded-md mt-1 max-h-48 overflow-auto w-full"
            @click.away="suggestions[field.name] = []">
            <template x-for="item in suggestions[field.name]" :key="item.id">
                <li @click="selectSuggestion(field.name, item)"
                    class="cursor-pointer px-3 py-2 hover:bg-primary-100"
                    x-text="item.label"></li>
            </template>
        </ul>
    </div>
</template>

{# Autocomplete multiple #}
<template x-if="field.type === 'autocomplete' && field.multiple">
    <div>
        <div class="flex flex-col">
            <div class="relative">
                <input type="text" x-model="inputLabels[field.name]"
                       @input.debounce.300ms="fetchSuggestions(field.name, $event.target.value)"
                       autocomplete="off"
                       placeholder="Start typing or add a new value..."
                       :class="inputLabelsList[field.name]?.length > 0
                           ? 'w-full py-1.5 px-3 text-sm border border-gray-300 rounded-t-md border-b-0 focus:outline-none focus:ring-1 focus:ring-primary-500 focus:border-primary-500'
                           : 'w-full py-1.5 px-3 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-primary-500 focus:border-primary-500'"/>
                <ul x-show="suggestions[field.name]?.length > 0"
                    class="absolute z-10 bg-white border border-gray-300 rounded-b-md shadow-lg max-h-48 overflow-auto w-full"
                    @click.away="suggestions[field.name] = []">
                    <template x-for="item in suggestions[field.name]" :key="item.id">
                        <li @click="selectAutocompleteItem(field.name, item)"
                            class="cursor-pointer px-3 py-2 hover:bg-primary-100"
                            x-text="item.label"></li>
                    </template>
                </ul>
            </div>
            <div class="border border-gray-300 border-t-0 rounded-b-md divide-y divide-gray-100 overflow-hidden"
                 x-show="inputLabelsList[field.name]?.length > 0">
                <template x-for="(label, idx) in inputLabelsList[field.name]" :key="idx">
                    <div class="flex items-center px-3 py-1 bg-white hover:bg-gray-50 group cursor-move"
                         draggable="true"
                         @dragstart="$event.dataTransfer.setData('text/plain', String(idx)); $event.currentTarget.classList.add('opacity-50')"
                         @dragend="$event.currentTarget.classList.remove('opacity-50')"
                         @dragover.prevent="$event.currentTarget.classList.add('bg-primary-50')"
                         @dragleave="$event.currentTarget.classList.remove('bg-primary-50')"
                         @drop.prevent="
                             $event.currentTarget.classList.remove('bg-primary-50');
                             const from = parseInt($event.dataTransfer.getData('text/plain'));
                             const to = idx;
                             if (from !== to) {
                                 const ids = [...formData.fields[field.name]];
                                 const labels = [...inputLabelsList[field.name]];
                                 const [movedId] = ids.splice(from, 1);
                                 const [movedLabel] = labels.splice(from, 1);
                                 ids.splice(to, 0, movedId);
                                 labels.splice(to, 0, movedLabel);
                                 formData.fields[field.name] = ids;
                                 inputLabelsList[field.name] = labels;
                             }
                         ">
                        <span class="cursor-grab text-gray-400 mr-3 select-none text-lg">⠿</span>
                        <span class="flex-1 text-sm text-gray-700" x-text="label"></span>
                        <button type="button" @click="removeAutocompleteItem(field.name, idx)"
                                class="text-gray-400 hover:text-red-500 ml-2 opacity-0 group-hover:opacity-100 transition-opacity">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                            </svg>
                        </button>
                    </div>
                </template>
            </div>
        </div>
        <!-- Stockage des ids -->
        <template x-for="(item, idx) in formData.fields[field.name]" :key="idx">
            <input type="hidden" :name="field.name + '[]'" :value="item"/>
        </template>
    </div>
</template>
