<div x-data="{ isRTL: document.dir === 'rtl' }" :dir="isRTL ? 'rtl' : 'ltr'">
    <div x-show="activeTab === 'settings'" class="flex-1 overflow-y-auto">
        {# <h2 class="text-lg font-semibold my-4 text-slate-900">{{ 'Page settings'|t }}</h2> #}
        <div class="space-y-6 bg-white px-6 py-8 rounded-xl shadow-sm">
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">{{ 'Page title'|t }}</label>
                <input @keydown.enter="saveVactoryPageNode()" x-model="settings.title"
                       class="w-full py-2 px-3 text-sm border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-300 focus:border-transparent transition-all duration-150"
                       type="text" name="title">
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">{{ 'Page description'|t }}</label>
                <textarea @keydown.enter="saveVactoryPageNode()" x-model="settings.summary"
                          class="w-full py-2 px-3 text-sm border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-300 focus:border-transparent transition-all duration-150"
                          name="summary" rows="3" placeholder="{{ 'Enter page description...'|t }}"></textarea>
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">{{ 'Alias (URL)'|t }}</label>
                <div class="flex">
                    <span
                            class="inline-flex items-center px-3 rounded-s-lg border border-e-0 border-slate-300 bg-slate-50 text-slate-400 text-sm">/</span>
                    <input @keydown.enter="saveVactoryPageNode()" x-model="settings.alias"
                           class="flex-1 py-2 px-3 text-sm border border-slate-300 rounded-e-lg focus:outline-none focus:ring-2 focus:ring-primary-300 focus:border-transparent transition-all duration-150"
                           type="text" name="alias">
                </div>
            </div>
        </div>

        {# Domain Settings Section #}
        {% if domain_access_enabled %}
            <div x-show="Object.keys(domainFields || {}).length > 0"
                 class="space-y-6 bg-white px-6 py-8 rounded-xl shadow-sm mt-6">
                <h3 class="text-lg font-semibold text-slate-900 border-b border-slate-200 pb-3">{{ 'Domain Settings'|t }}
                </h3>
                <template x-for="(field, fieldName) in (domainFields || {})" :key="field.name">
                    {% include "@vactory_dashboard/_components/fields/form-field-builder.html.twig" with {
                        field: 'field',
                        formData: 'formData',
                        isEdit: true,
                        language: language,
                        node_default_lang: node_default_lang
                    } %}
                </template>
            </div>
        {% endif %}

        {# Search Settings Section #}
        {% if search_api_exclude_entity_enabled %}
            <div x-show="Object.keys(searchFields || {}).length > 0"
                 class="space-y-6 bg-white px-6 py-8 rounded-xl shadow-sm mt-6">
                <h3 class="text-lg font-semibold text-slate-900 border-b border-slate-200 pb-3">{{ 'Exclude from search'|t }}</h3>
                <template x-for="(field, fieldName) in (searchFields || {})" :key="field.name">
                    {% include "@vactory_dashboard/_components/fields/form-field-builder.html.twig" with {
                        field: 'field',
                        formData: 'formData',
                        isEdit: true,
                        language: language,
                        node_default_lang: node_default_lang
                    } %}
                </template>
            </div>
        {% endif %}

        {# XML Sitemap Section #}
        {% if xmlsitemap_enabled %}
            <div class="space-y-6 bg-white px-6 py-8 rounded-xl shadow-sm mt-6">
                <h3 class="text-lg font-semibold text-slate-900 border-b border-slate-200 pb-3">{{ 'XML Sitemap'|t }}</h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    {# Inclusion #}
                    <div class="form-group">
                        <label class="block text-sm font-medium text-slate-700 mb-2">{{ 'Inclusion'|t }}</label>
                        <select x-model="formData.xmlsitemap.status"
                                class="w-full rounded-lg border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm">
                            {% for key, value in xmlsitemap_enabled.status %}
                                <option value="{{ key }}">{{ value }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    {# Priority #}
                    <div class="form-group" x-show="formData.xmlsitemap.status !== '0'">
                        <label class="block text-sm font-medium text-slate-700 mb-2">{{ 'Priority'|t }}</label>
                        <select x-model="formData.xmlsitemap.priority"
                                class="w-full rounded-lg border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm">
                            {% for key, value in xmlsitemap_enabled.priority %}
                                <option value="{{ key }}">{{ value }}</option>
                            {% endfor %}
                        </select>
                        <p class="mt-1 text-xs text-slate-500">{{ 'The priority of this URL relative to other URLs on your
                        site.'|t }}</p>
                    </div>

                    {# Change Frequency #}
                    <div class="form-group" x-show="formData.xmlsitemap.status !== '0'">
                        <label class="block text-sm font-medium text-slate-700 mb-2">{{ 'Change frequency'|t }}</label>
                        <select x-model="formData.xmlsitemap.changefreq"
                                class="w-full rounded-lg border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm">
                            {% for key, value in xmlsitemap_enabled.changefreq %}
                                <option value="{{ key }}">{{ value }}</option>
                            {% endfor %}
                        </select>
                        <p class="mt-1 text-xs text-slate-500">{{ 'Select the frequency of changes.'|t }}</p>
                    </div>
                </div>
            </div>
        {% endif %}

        {# Scheduler Settings Section #}
        {% if scheduler_enabled %}
            <div class="space-y-6 bg-white px-6 py-8 rounded-xl shadow-sm mt-6">
                <h3 class="text-lg font-semibold text-slate-900 border-b border-slate-200 pb-3">{{ 'Scheduling Options'|t }}
                </h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    {% if scheduler_publish_enabled %}
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">{{ 'Publish on'|t }}</label>
                        <input type="datetime-local" x-model="settings.publish_on"
                               class="w-full py-2 px-3 text-sm border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-300 focus:border-transparent transition-all duration-150">
                        <p class="mt-1 text-xs text-slate-500">{{ 'Leave empty to publish immediately or manually.'|t }}</p>
                    </div>
                    {% endif %}
                    {% if scheduler_unpublish_enabled %}
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1">{{ 'Unpublish on'|t }}</label>
                            <input type="datetime-local" x-model="settings.unpublish_on"
                                   class="w-full py-2 px-3 text-sm border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-300 focus:border-transparent transition-all duration-150">
                            <p class="mt-1 text-xs text-slate-500">{{ 'Leave empty to keep the content published
                        indefinitely.'|t }}</p>
                        </div>
                    {% endif %}
                </div>
            </div>
        {% endif %}
    </div>
</div>